@{
    // Cambia esta ruta a tu archivo de audio en wwwroot
    var audioSrc = "/Sounds/SkyrimThemeSongFull(Dovahkiin Song).mp3";
    var trackName = "Skyrim Theme";
}

<!-- Audio Element -->
<audio id="bg-audio" loop preload="auto">
    <source src="@audioSrc" type="audio/mpeg" />
    Tu navegador no soporta audio HTML5.
</audio>

<!-- Controller Widget -->
<div id="audio-controller">

    <!-- Panel expandible -->
    <div id="audio-panel" role="dialog" aria-label="Controles de audio">

        <div class="audio-panel-header">
            <span class="audio-panel-title"> Audio</span>
        </div>

        <!-- Track info con visualizador -->
        <div class="audio-track-info" id="audio-track-info">
            <div class="audio-visualizer" id="audio-visualizer">
                <div class="audio-bar"></div>
                <div class="audio-bar"></div>
                <div class="audio-bar"></div>
                <div class="audio-bar"></div>
            </div>
            <span class="audio-track-name">@trackName</span>
        </div>

        <div class="audio-controls">
            <!-- Volumen -->
            <div class="audio-control-row">
                <span class="audio-label">Vol</span>
                <input type="range"
                       class="audio-slider"
                       id="volume-slider"
                       min="0" max="100" value="60"
                       aria-label="Volumen" />
                <span class="audio-value" id="volume-display">60%</span>
            </div>

            <div class="audio-divider"></div>

            <!-- Botón Play/Pause -->
            <button class="audio-play-btn" id="play-pause-btn" aria-label="Reproducir o pausar">
                ▶ Reproducir
            </button>
        </div>
    </div>

    <!-- Botón flotante siempre visible -->
    <button id="audio-toggle-btn"
            aria-label="Abrir controles de audio"
            title="Controles de audio">
        <!-- Ícono de audio (SVG inline) -->
        <svg id="audio-icon-sound" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02z" />
        </svg>
        <!-- Ícono muted (oculto por defecto) -->
        <svg id="audio-icon-muted" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" style="display:none">
            <path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z" />
        </svg>
    </button>
</div>

@section Scripts {
    <script src="~/js/audio-controller.js"></script>
}
