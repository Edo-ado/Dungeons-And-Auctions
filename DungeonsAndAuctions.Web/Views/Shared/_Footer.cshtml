@* Path: DungeonsAndAuctions.Web/Views/Shared/_Footer.cshtml *@
@* CORRECCIONES:
   - Links de navegación ahora usan asp-controller/asp-action en lugar de href="#"
   - Se eliminaron los <link href="#" rel="stylesheet" /> que eran un error (eran placeholders de redes sociales)
*@
<div class="max-w-7xl mx-auto px-8 py-14
            grid grid-cols-1 md:grid-cols-3 gap-12
            text-sm text-yellow-400">

    <!-- Marca -->
    <div>
        <h2 class="font-['Cinzel'] text-xl tracking-[0.25em]
                   text-yellow-400 mb-4 uppercase
                   drop-shadow-[0_0_6px_rgba(250,204,21,0.6)]">
            Dungeons & Auctions
        </h2>
        <p class="text-yellow-500/90
                  drop-shadow-[0_0_6px_rgba(220,38,38,0.4)]">
            Donde los héroes no solo luchan, también pujan.
        </p>
    </div>

    <!-- Navegación -->
    <div>
        <h4 class="font-['Cinzel'] tracking-widest mb-4
                   text-yellow-400 uppercase text-sm
                   drop-shadow-[0_0_6px_rgba(250,204,21,0.5)]">
            Explorar
        </h4>
        <ul class="space-y-3">
            <li>
                <a asp-controller="Auctions" asp-action="Index"
                   class="text-yellow-300 hover:text-yellow-400 transition duration-300
                          hover:drop-shadow-[0_0_8px_rgba(250,204,21,0.8)]">
                    Subastas
                </a>
            </li>
            <li>
                <a asp-controller="Object" asp-action="Index"
                   class="text-yellow-300 hover:text-yellow-400 transition duration-300
                          hover:drop-shadow-[0_0_8px_rgba(250,204,21,0.8)]">
                    Objetos
                </a>
            </li>
            <li>
                <a asp-controller="User" asp-action="Details"
                   asp-route-id="@(Context.Session.GetInt32("UserId") ?? 0)"
                   class="text-yellow-300 hover:text-yellow-400 transition duration-300
                          hover:drop-shadow-[0_0_8px_rgba(250,204,21,0.8)]">
                    Mi Perfil
                </a>
            </li>
        </ul>
    </div>

    <!-- El Reino -->
    <div>
        <h4 class="font-['Cinzel'] tracking-widest mb-4
                   text-yellow-400 uppercase text-sm
                   drop-shadow-[0_0_6px_rgba(250,204,21,0.5)]">
            El Reino
        </h4>
        <p class="text-yellow-300/80
                  drop-shadow-[0_0_4px_rgba(250,204,21,0.4)] mb-4">
            Forjado en código y fuego desde 2026.
        </p>
      
        <div class="flex gap-4 mt-2">
            <span class="text-stone-600 text-xs italic font-serif">Redes sociales — próximamente</span>
        </div>
    </div>
</div>

<div class="border-t border-yellow-600
            text-center py-6
            text-xs text-red-400
            tracking-wider
            drop-shadow-[0_0_6px_rgba(250,204,21,0.4)]">
    © @DateTime.Now.Year Dungeons & Auctions · Todos los derechos reservados.
</div>
