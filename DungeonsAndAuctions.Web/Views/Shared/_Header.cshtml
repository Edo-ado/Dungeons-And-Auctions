                            Subastas
                            <svg class="w-3 h-3 transition-transform duration-300" id="subastas-arrow"
                                 fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                            </svg>
                        </a>

                        <div id="subastas-dropdown"
                             class="absolute top-full left-1/2 -translate-x-1/2 mt-3 min-w-[200px]
