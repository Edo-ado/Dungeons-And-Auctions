<nav class="bg-[#2a1f1a]
            border-t-4 border-yellow-700
            border-b border-yellow-900
            shadow-[0_12px_30px_rgba(0,0,0,0.85)]">
    <div class="mx-auto px-8">
        <div class="flex items-center justify-between h-24">
            <a asp-controller="Home" asp-action="Index">
