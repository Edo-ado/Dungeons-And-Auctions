                            <div class="h-px bg-gradient-to-r from-transparent via-yellow-700 to-transparent"></div>
                            <a asp-controller="Auctions" asp-action="Index"
                               class="block px-6 py-3 text-sm
                                      hover:text-yellow-400
                                      hover:bg-yellow-400/5
                                      hover:drop-shadow-[0_0_8px_rgba(255,215,0,0.8)]
                                      transition duration-300
                                      border-b border-yellow-900/50">
                                Ver Subastas
                            </a>
                            <a asp-controller="Auctions" asp-action="GetAllAuctionsInactive"
                               class="block px-6 py-3 text-sm
