@* _SubastasBaneadas.cshtml — solo subastas con estado "banned" *@
@model IEnumerable<D_A.Application.DTOs.AuctionsDTO>

@if (!Model.Any())
{
    <div class="flex flex-col items-center justify-center py-32 text-center">
        <div class="text-red-900 text-6xl mb-6">⚜</div>
        <p class="text-stone-500 font-serif italic text-lg">No hay subastas baneadas en el reino.</p>
    </div>
}
else
{
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8" id="auctions-grid">
        @foreach (var item in Model)
        {
            @await Html.PartialAsync("_AuctionCard", item)
        }
    </div>
}
