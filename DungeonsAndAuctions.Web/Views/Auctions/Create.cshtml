@model D_A.Application.DTOs.AuctionsDTO

@{
    ViewData["Title"] = "Convocar Subasta";
    var objects = ViewBag.Objects as IEnumerable<D_A.Application.DTOs.ObjectsDTO> ?? new List<D_A.Application.DTOs.ObjectsDTO>();
}

<div class="relative min-h-screen overflow-hidden font-['Cinzel']" style="background-color: #1a1412;">

    <div class="grain-overlay"></div>

    <!-- Embers -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="ember ember-1"></div>
        <div class="ember ember-2"></div>
        <div class="ember ember-3"></div>
        <div class="ember ember-4"></div>
        <div class="ember ember-5"></div>
        <div class="ash ash-1"></div>
        <div class="ash ash-2"></div>
        <div class="ash ash-3"></div>
    </div>

    <div class="relative z-10 h-1 bg-gradient-to-r from-transparent via-yellow-600 to-transparent"></div>

    <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">

        <!-- HEADER -->
        <div class="flex flex-col items-center text-center mb-14 animate-rise">
            <div class="flex items-center gap-4 mb-5">
                <div class="h-px w-20 bg-gradient-to-r from-transparent to-yellow-700"></div>
                <svg class="w-5 h-5 text-yellow-700" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z" />
                </svg>
                <div class="h-px w-20 bg-gradient-to-l from-transparent to-yellow-700"></div>
            </div>
            <p class="text-yellow-700 text-xs tracking-[0.5em] uppercase mb-2">Nuevo Edicto Real</p>
            <h1 class="text-3xl md:text-4xl text-yellow-100 tracking-[0.12em] uppercase mb-1"
                style="text-shadow: 0 0 40px rgba(180,130,0,0.3);">
                Convocar Subasta
            </h1>
            <div class="flex items-center gap-6 mt-5">
                <div class="h-px w-24 md:w-36 bg-gradient-to-r from-transparent via-yellow-800 to-yellow-600"></div>
                <div class="text-red-700 text-2xl drop-shadow-[0_0_12px_rgba(180,0,0,0.6)]">⚔</div>
                <div class="h-px w-24 md:w-36 bg-gradient-to-l from-transparent via-yellow-800 to-yellow-600"></div>
            </div>
        </div>

        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="idusercreator" />
            <input type="hidden" asp-for="idstate" value="6" />
            <input type="hidden" asp-for="IsActive" value="true" />
            <input type="hidden" asp-for="idobject" id="selectedObjectId" />

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 animate-fade-in-delay">

                <!-- LEFT: OBJETO SELECCIONADO -->
                <div class="md:col-span-1 flex flex-col gap-6">
                    <div class="medieval-panel relative overflow-hidden">
                        <div class="corner tl"></div><div class="corner tr"></div>
                        <div class="corner bl"></div><div class="corner br"></div>

                        <!-- Preview imagen objeto -->
                        <div id="objectImagePreview" class="aspect-[4/3] flex flex-col items-center justify-center bg-[#150f0c]">
                            <span class="text-yellow-900 text-5xl mb-2">⚜</span>
                            <span class="text-stone-600 text-xs font-serif italic">Sin objeto seleccionado</span>
                        </div>

                        <div class="p-5">
                            <p id="objectNamePreview" class="text-stone-400 text-sm font-serif italic text-center mb-4">
                                Ninguna reliquia seleccionada
                            </p>

                            <!-- Botón abrir modal -->
                            <button type="button" id="btnOpenModal"
                                    class="w-full py-2 border border-yellow-700 text-yellow-500 text-xs uppercase tracking-widest
               hover:bg-yellow-900/20 hover:border-yellow-500 hover:text-yellow-300
               transition-all duration-300 font-bold">
                                ⚔ Seleccionar Reliquia
                            </button>
                            <span asp-validation-for="idobject" class="text-red-500 text-xs mt-1 block"></span>
                        </div>
                    </div>

                    <!-- Estado info -->
                    <div class="medieval-panel p-5">
                        <div class="corner tl"></div><div class="corner tr"></div>
                        <div class="corner bl"></div><div class="corner br"></div>
                        <h2 class="section-title mb-4">⚜ Estado Inicial</h2>
                        <div class="flex flex-col gap-3">
                            <div class="stat-block">
                                <span class="stat-label">Estado</span>
                                <span class="stat-value text-sm text-stone-400">Borrador (Draft)</span>
                            </div>
                            <div class="stat-block">
                                <span class="stat-label">Activa al crear</span>
                                <span class="stat-value text-sm text-green-400">Sí</span>
                            </div>

                                @if (ViewBag.UserName != null)
                {

                            <div class="stat-block">
                                <span class="stat-label">Usuario creador de la Subasta</span>
                                    <span class="stat-value text-sm text-green-400">@ViewBag.UserName <span class="text-yellow-700">#@ViewBag.UserId</span></span>
                            </div>

                }

                        </div>
                    </div>
                </div>

                <!-- RIGHT: FORMULARIO -->
                <div class="md:col-span-2 flex flex-col gap-6">
                    <div class="medieval-panel p-6">
                        <div class="corner tl"></div><div class="corner tr"></div>
                        <div class="corner bl"></div><div class="corner br"></div>

                        <h2 class="section-title mb-6">♛ Datos de la Subasta</h2>

                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">

                            <!-- StartDate -->
                            <div class="flex flex-col gap-1">
                                <label class="field-label">Fecha de Inicio</label>
                                <input asp-for="StartDate" type="date"
                                       class="field-input" />
                                <span asp-validation-for="StartDate" class="text-red-500 text-xs"></span>
                            </div>

                            <!-- EndDate -->
                            <div class="flex flex-col gap-1">
                                <label class="field-label">Fecha de Cierre</label>
                                <input asp-for="EndDate" type="date"
                                       class="field-input" />
                                <span asp-validation-for="EndDate" class="text-red-500 text-xs"></span>
                            </div>

                            <!-- BasePrice -->
                            <div class="flex flex-col gap-1">
                                <label class="field-label">Precio Base (₡)</label>
                                <input asp-for="BasePrice" type="number" step="0.01" min="0"
                                       class="field-input"
                                       placeholder="0.00" />
                                <span asp-validation-for="BasePrice" class="text-red-500 text-xs"></span>
                            </div>

                            <!-- IncrementoMinimo -->
                            <div class="flex flex-col gap-1">
                                <label class="field-label">Incremento Mínimo (₡)</label>
                                <input asp-for="IncrementoMinimo" type="number" step="0.01" min="0"
                                       class="field-input"
                                       placeholder="0.00" />
                                <span asp-validation-for="IncrementoMinimo" class="text-red-500 text-xs"></span>
                            </div>

                        </div>

                        <!-- Validation summary -->
                        <div asp-validation-summary="ModelOnly" class="text-red-500 text-xs mt-4 font-serif italic"></div>
                    </div>

                    <!-- Actions -->
                    <div class="flex items-center justify-between pt-2">


                        <a onclick="history.back()" data-no-ajax
                           class="px-6 py-2 border border-stone-700/60 text-stone-400 text-xs uppercase tracking-[0.15em]
          hover:border-stone-500 hover:text-stone-200 transition-all duration-300 cursor-pointer">
                            ← Volver
                        </a>


                        <button type="submit"
                                class="px-8 py-2 bg-yellow-800/40 border border-yellow-600 text-yellow-400 text-xs uppercase tracking-[0.15em]
                                       hover:bg-yellow-700/40 hover:border-yellow-400 hover:text-yellow-200 transition-all duration-300 font-bold">
                            ⚔ Proclamar Subasta
                        </button>


                    </div>
                </div>

            </div>
        </form>

        <!-- Footer -->
        <div class="mt-16 text-center">
            <div class="flex justify-center items-center gap-4 opacity-20">
                <div class="h-px w-24 bg-yellow-700"></div>
                <img src="/Images/Logo/ShortLogo.png" class="h-8 grayscale" alt="logo" />
                <div class="h-px w-24 bg-yellow-700"></div>
            </div>
        </div>
    </div>

    <div class="relative z-10 h-1 bg-gradient-to-r from-transparent via-yellow-600 to-transparent mt-4"></div>
</div>

<!-- ===================== MODAL OBJETOS ===================== -->
<div id="objectModal"
     class="fixed inset-0 z-[200] hidden items-center justify-center"
     style="background: rgba(10,6,4,0.92);">
    <div class="relative w-full max-w-4xl max-h-[85vh] flex flex-col mx-4
                bg-[#1e1410] border border-yellow-900 shadow-[0_0_60px_rgba(0,0,0,0.9)]">

        <!-- Modal header -->
        <div class="flex items-center justify-between px-6 py-4 border-b border-yellow-900/50 bg-[#2a1a12]">
            <div>
                <h2 class="text-yellow-500 text-xs uppercase tracking-[0.3em] font-bold font-['Cinzel']">
                    ⚜ Seleccionar Reliquia
                </h2>
                <p class="text-stone-600 text-xs font-serif italic mt-1">Elige el objeto que será subastado</p>
            </div>
            <button onclick="closeObjectModal()"
                    class="text-stone-600 hover:text-yellow-400 transition-colors text-xl leading-none">
                ✕
            </button>
        </div>

        <!-- Search -->
        <div class="px-6 py-3 border-b border-yellow-900/30">
            <input type="text" id="objectSearch" placeholder="Buscar reliquia..."
                   oninput="filterObjects()"
                   class="w-full bg-[#150f0c] border border-yellow-900/40 text-stone-300 text-xs
                          px-4 py-2 font-['Cinzel'] placeholder-stone-700
                          focus:outline-none focus:border-yellow-700 transition-colors" />
        </div>

        <!-- Objects grid -->
        <div class="overflow-y-auto flex-1 p-6">
            <div id="objectsGrid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
                @foreach (var obj in objects)
                {
                    var firstImg = obj.Imagenes?.FirstOrDefault();
                    <div class="object-card cursor-pointer border border-yellow-900/30 bg-[#211810]
                                    hover:border-yellow-600 hover:bg-[#2d1f14] transition-all duration-200 group"
                         data-id="@obj.Id"
                         data-name="@obj.Name"
                         data-img="@(firstImg != null ? Convert.ToBase64String(firstImg) : "")"
                         onclick="selectObject(this)">

                        <!-- Imagen -->
                        <div class="aspect-[4/3] overflow-hidden bg-[#150f0c]">
                            @if (firstImg != null && firstImg.Length > 0)
                            {
                                <img src="data:image/jpeg;base64,@Convert.ToBase64String(firstImg)"
                                     alt="@obj.Name"
                                     class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
                            }
                            else
                            {
                                <div class="w-full h-full flex items-center justify-center">
                                    <span class="text-yellow-900 text-3xl">⚜</span>
                                </div>
                            }
                        </div>

                        <!-- Info -->
                        <div class="p-3">
                            <p class="text-stone-300 text-xs font-bold uppercase tracking-wide truncate
                                          group-hover:text-yellow-400 transition-colors font-['Cinzel']">
                                @obj.Name
                            </p>
                            <p class="text-yellow-900 text-[10px] font-mono mt-1">#@obj.Id</p>
                        </div>
                    </div>
                }
            </div>

            @if (!objects.Any())
            {
                <div class="flex flex-col items-center justify-center py-16">
                    <span class="text-yellow-900 text-4xl mb-3">⚜</span>
                    <p class="text-stone-600 font-serif italic text-sm">No hay reliquias disponibles.</p>
                </div>
            }
        </div>

        <!-- Modal footer -->
        <div class="px-6 py-4 border-t border-yellow-900/30 flex justify-end">
            <button onclick="closeObjectModal()"
                    class="px-6 py-2 border border-stone-700 text-stone-500 text-xs uppercase tracking-widest
                           hover:border-stone-500 hover:text-stone-300 transition-all font-['Cinzel']">
                Cancelar
            </button>
        </div>
    </div>
</div>

<script>

    document.getElementById('btnOpenModal').addEventListener('click', openObjectModal);

    function openObjectModal() {
        const modal = document.getElementById('objectModal');
        modal.classList.remove('hidden');
        modal.classList.add('flex');
    }

    function closeObjectModal() {
        const modal = document.getElementById('objectModal');
        modal.classList.add('hidden');
        modal.classList.remove('flex');
    }

    function selectObject(card) {
        const id = card.dataset.id;
        const name = card.dataset.name;
        const img = card.dataset.img;
        document.getElementById('selectedObjectId').value = id;
        document.getElementById('objectNamePreview').textContent = name;
        const preview = document.getElementById('objectImagePreview');
        if (img) {
            preview.innerHTML = `<img src="data:image/jpeg;base64,${img}" class="w-full h-full object-cover" alt="${name}" />`;
        } else {
            preview.innerHTML = `<div class="w-full h-full flex flex-col items-center justify-center bg-[#150f0c]">
                <span class="text-yellow-900 text-5xl mb-2">⚜</span>
                <span class="text-stone-600 text-xs font-serif italic">Sin imagen</span>
            </div>`;
        }
        document.querySelectorAll('.object-card').forEach(c => {
            c.classList.remove('border-yellow-500', 'bg-yellow-900/20');
        });
        card.classList.add('border-yellow-500', 'bg-yellow-900/20');
        closeObjectModal();
    }

    function filterObjects() {
        const query = document.getElementById('objectSearch').value.toLowerCase();
        document.querySelectorAll('.object-card').forEach(card => {
            const name = card.dataset.name.toLowerCase();
            card.style.display = name.includes(query) ? '' : 'none';
        });
    }

    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closeObjectModal();
    });
</script>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}



<style>
    @@keyframes rise {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes float {
        0%, 100% {
            transform: translateY(0) translateX(0);
            opacity: 0;
        }

        10% {
            opacity: 1;
        }

        90% {
            opacity: 0.6;
        }

        100% {
            transform: translateY(-100vh) translateX(20px);
            opacity: 0;
        }
    }

    @@keyframes grain {
        0%, 100% {
            transform: translate(0,0);
        }

        25% {
            transform: translate(1px,1px);
        }

        50% {
            transform: translate(-1px,0);
        }

        75% {
            transform: translate(0,-1px);
        }
    }

    html, body {
        margin: 0;
        padding: 0;
        background-color: #1a1412;
    }

    .animate-rise {
        animation: rise 1s ease-out forwards;
    }

    .animate-fade-in-delay {
        animation: fadeIn 1.2s ease-out 0.3s both;
    }

    .grain-overlay {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 100;
        opacity: 0.035;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
        animation: grain 0.5s steps(1) infinite;
    }

    .ember {
        position: absolute;
        width: 3px;
        height: 3px;
        border-radius: 50%;
        background: #f97316;
        box-shadow: 0 0 6px #f97316, 0 0 12px #ea580c;
        animation: float linear infinite;
        bottom: -10px;
    }

    .ember-1 {
        left: 10%;
        animation-duration: 8s;
        animation-delay: 0s
    }

    .ember-2 {
        left: 25%;
        animation-duration: 11s;
        animation-delay: 2s
    }

    .ember-3 {
        left: 50%;
        animation-duration: 9s;
        animation-delay: 4s
    }

    .ember-4 {
        left: 70%;
        animation-duration: 13s;
        animation-delay: 1s
    }

    .ember-5 {
        left: 85%;
        animation-duration: 7s;
        animation-delay: 3s
    }

    .ash {
        position: absolute;
        width: 2px;
        height: 2px;
        border-radius: 50%;
        background: #9ca3af;
        box-shadow: 0 0 4px #6b7280;
        animation: float linear infinite;
        bottom: -10px
    }

    .ash-1 {
        left: 20%;
        animation-duration: 12s;
        animation-delay: 1s
    }

    .ash-2 {
        left: 55%;
        animation-duration: 10s;
        animation-delay: 5s
    }

    .ash-3 {
        left: 80%;
        animation-duration: 14s;
        animation-delay: 3s
    }

    .medieval-panel {
        position: relative;
        background: #211810;
        border: 1px solid rgba(120,83,15,0.35);
        transition: border-color 0.4s, box-shadow 0.4s;
    }

        .medieval-panel:hover {
            border-color: rgba(180,130,0,0.5);
            box-shadow: 0 0 30px rgba(100,60,0,0.2);
        }

    .corner {
        position: absolute;
        width: 14px;
        height: 14px;
    }

        .corner.tl {
            top: 6px;
            left: 6px;
            border-top: 1px solid #78350f80;
            border-left: 1px solid #78350f80;
        }

        .corner.tr {
            top: 6px;
            right: 6px;
            border-top: 1px solid #78350f80;
            border-right: 1px solid #78350f80;
        }

        .corner.bl {
            bottom: 6px;
            left: 6px;
            border-bottom: 1px solid #78350f80;
            border-left: 1px solid #78350f80;
        }

        .corner.br {
            bottom: 6px;
            right: 6px;
            border-bottom: 1px solid #78350f80;
            border-right: 1px solid #78350f80;
        }

    .medieval-panel:hover .corner {
        border-color: #b4530980;
    }

    .section-title {
        color: #fcd34d;
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.25em;
        font-family: 'Cinzel', serif;
    }

    .stat-block {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
        padding: 0.65rem 0.85rem;
        background: rgba(0,0,0,0.25);
        border: 1px solid rgba(120,83,15,0.2);
    }

    .stat-label {
        font-size: 0.55rem;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        color: #78716c;
    }

    .stat-value {
        font-size: 0.95rem;
        color: #fcd34d;
        font-family: 'Cinzel', serif;
        font-weight: 600;
    }

    .field-label {
        font-size: 0.55rem;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        color: #78716c;
        font-family: 'Cinzel', serif;
    }

    .field-input {
        background: #150f0c;
        border: 1px solid rgba(120,83,15,0.4);
        color: #d6d3d1;
        font-family: 'Cinzel', serif;
        font-size: 0.8rem;
        padding: 0.5rem 0.75rem;
        transition: border-color 0.3s;
        width: 100%;
    }

        .field-input:focus {
            outline: none;
            border-color: rgba(180,130,0,0.7);
            box-shadow: 0 0 0 1px rgba(180,130,0,0.2);
        }

        .field-input::placeholder {
            color: #44403c;
        }

        /* Date input calendar icon color */
        .field-input::-webkit-calendar-picker-indicator {
            filter: invert(0.5) sepia(1) saturate(2) hue-rotate(10deg);
        }
</style>