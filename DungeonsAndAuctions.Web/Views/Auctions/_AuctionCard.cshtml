@* Partial reutilizable: recibe un AuctionsDTO individual *@
@model D_A.Application.DTOs.AuctionsDTO

@{
    var statusKey = Model.IdstateNavigation.Name?.ToLower();
    var (badgeClass, badgeLabel) = statusKey switch
    {
        "open"   => ("badge-open",    "Abierta"),
        "close"  => ("badge-closed",  "Cerrada"),
        "banned" => ("badge-banned",  "Baneada"),
        _        => ("badge-default", Model.IdstateNavigation.Name ?? "—")
    };

    // tomar la primera imagen disponible del objeto (si existe)
    var firstImage = Model.IdobjectNavigation?.IdImageNavigation?.FirstOrDefault();
    var hasImage = firstImage != null && firstImage.ImageData?.Length > 0;
}
<div class="auction-card group relative border border-yellow-900/40 bg-[#211810] flex flex-col
            transition-all duration-500 hover:border-yellow-700/60
            hover:shadow-[0_0_35px_rgba(100,60,0,0.25)]"
     data-status="@statusKey">

        <!-- IMAGE -->
    <!-- IMAGE -->
    <div class="relative w-full aspect-[4/3] overflow-hidden bg-[#0e0a07]">
        @if (hasImage)
        {
            
            <div class="absolute inset-0 scale-110 blur-2xl opacity-40 saturate-150"
                 style="background-image: url('data:image/jpeg;base64,@Convert.ToBase64String(firstImage.ImageData)');
                        background-size: cover; background-position: center;">
            </div>

           
            <img class="absolute inset-0 w-full h-full object-contain transition-transform duration-700 group-hover:scale-105 relative z-10 p-4"
                 src="data:image/jpeg;base64,@Convert.ToBase64String(firstImage.ImageData)"
                 alt="@Model.IdobjectNavigation?.Name"
                 loading="lazy" />
        }
        else
        {
            <div class="absolute inset-0 flex flex-col justify-center items-center bg-[#1a1412]">
                <span class="text-yellow-900 text-5xl mb-2">⚜</span>
                <span class="text-stone-600 text-xs font-serif italic">Sin imagen</span>
            </div>
        }
        <div class="absolute inset-0 bg-gradient-to-t from-[#211810] via-[#211810]/10 to-transparent z-20"></div>
        <div class="absolute top-3 right-3 z-30">
            <span class="@badgeClass">@badgeLabel</span>
        </div>
    </div>

    <!-- CONTENT (sin cambios relevantes) -->
    <div class="flex flex-col flex-1 p-6">

        <h2 class="text-yellow-100 text-base uppercase tracking-[0.12em] mb-1 leading-tight">
            @Model.IdobjectNavigation?.Name
        </h2>
        <p class="text-stone-500 text-xs font-serif italic mb-5">
            Ofrecida por <span class="text-yellow-700">@Model.IdusercreatorNavigation.UserName</span>
        </p>

        <div class="h-px bg-gradient-to-r from-transparent via-yellow-900/50 to-transparent mb-5"></div>

        <div class="grid grid-cols-2 gap-3 mb-5">
            <div class="stat-block">
                <span class="stat-label">Precio Base</span>
                <span class="stat-value">@Model.BasePrice.ToString("N2") <span class="text-yellow-800 text-xs">Oz</span></span>
            </div>
            <div class="stat-block">
                <span class="stat-label">Inc. Mínimo</span>
                <span class="stat-value">@Model.IncrementoMinimo.ToString("N2") <span class="text-yellow-800 text-xs">Oz</span></span>
            </div>
            <div class="stat-block col-span-2">
                <span class="stat-label">Pujas Totales</span>
                <span class="stat-value text-yellow-400">@Model.TotalBids</span>
            </div>
        </div>

        <div class="flex-1"></div>
        <div class="h-px bg-gradient-to-r from-transparent via-yellow-900/40 to-transparent mb-5"></div>

        <!-- ACTIONS -->
        <div class="flex items-center justify-between gap-2">
            <a asp-action="Details" asp-route-id="@Model.Id"
               class="flex-1 text-center py-2 px-3 border border-yellow-800/60 text-yellow-600 text-xs uppercase tracking-[0.15em]
                      hover:border-yellow-500 hover:text-yellow-400 hover:bg-yellow-900/10 transition-all duration-300">
                Detalles
            </a>
            <a asp-action="Edit" asp-route-id="@Model.Id"
               class="flex-1 text-center py-2 px-3 border border-stone-700/60 text-stone-400 text-xs uppercase tracking-[0.15em]
                      hover:border-stone-500 hover:text-stone-200 hover:bg-stone-800/20 transition-all duration-300">
                Editar
            </a>
            <a asp-action="Delete" asp-route-id="@Model.Id"
               class="py-2 px-3 border border-red-900/50 text-red-700 text-xs uppercase tracking-[0.15em]
                      hover:border-red-600 hover:text-red-500 hover:bg-red-900/10 transition-all duration-300">
                ✕
            </a>
        </div>

    </div>
</div>
