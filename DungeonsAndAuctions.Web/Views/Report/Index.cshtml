                </div>
            </div>

            <!-- ═══════════════════════════════════════ -->
            <!-- REPORTE 2: ACTIVIDAD DEL SISTEMA        -->
            <!-- ═══════════════════════════════════════ -->
            <div class="group relative border border-yellow-900/50 bg-[#2a1f1a]/90 p-8 hover:border-yellow-700 transition-all duration-500 hover:shadow-[0_0_30px_rgba(100,60,0,0.2)]">
                <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-[#1a1412] px-3">
                    <span class="text-red-700 text-2xl">⚜</span>
                </div>
                <div class="absolute top-2 left-2 w-4 h-4 border-t border-l border-yellow-800"></div>
                <div class="absolute top-2 right-2 w-4 h-4 border-t border-r border-yellow-800"></div>
                <div class="absolute bottom-2 left-2 w-4 h-4 border-b border-l border-yellow-800"></div>
                <div class="absolute bottom-2 right-2 w-4 h-4 border-b border-r border-yellow-800"></div>

                <h2 class="text-yellow-500 uppercase tracking-[0.2em] text-sm font-bold text-center mb-2 mt-2">
                    Actividad del Sistema
                </h2>
                <p class="text-stone-500 text-xs font-serif italic text-center mb-6">
                    Resumen general del reino: subastas creadas, pujas realizadas y subastas finalizadas.
                </p>

                <div class="space-y-4">
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="text-yellow-700 text-xs tracking-widest uppercase block mb-1">Desde</label>
                            <input type="date" id="system-date-from"
                                   class="w-full bg-[#1a1412] border border-yellow-900/60 text-stone-300 text-sm px-3 py-2 focus:outline-none focus:border-yellow-600 transition-colors" />
                        </div>
                        <div>
                            <label class="text-yellow-700 text-xs tracking-widest uppercase block mb-1">Hasta</label>
                            <input type="date" id="system-date-to"
                                   class="w-full bg-[#1a1412] border border-yellow-900/60 text-stone-300 text-sm px-3 py-2 focus:outline-none focus:border-yellow-600 transition-colors" />
                        </div>
                    </div>

                    <div id="system-error" class="hidden text-red-500 text-xs font-serif italic text-center py-1"></div>

                    <!-- Opciones de visualización -->
                    <div>
                        <label class="text-yellow-700 text-xs tracking-widest uppercase block mb-2">Tipo de Visualización</label>
