                    <canvas id="system-chart" class="mt-6 w-full" height="200"></canvas>
                </div>
            </div>

        </div>
    </div>

    <div class="relative z-10 h-1 bg-gradient-to-r from-transparent via-yellow-600 to-transparent mt-10"></div>
</div>

<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    let systemChart = null;

    function validateDates(fromId, toId, errorId) {
        const from = document.getElementById(fromId).value;
        const to = document.getElementById(toId).value;
        const errorEl = document.getElementById(errorId);

        if (!from || !to) {
            errorEl.textContent = "Por favor selecciona ambas fechas.";
            errorEl.classList.remove("hidden");
            return null;
        }
        if (new Date(from) > new Date(to)) {
            errorEl.textContent = "La fecha de inicio no puede ser mayor a la fecha final.";
            errorEl.classList.remove("hidden");
            return null;
        }
        errorEl.classList.add("hidden");
        return { from, to };
    }

    function generateBuyerReport() {
        const dates = validateDates("buyer-date-from", "buyer-date-to", "buyer-error");
        if (!dates) return;

        const loading = document.getElementById("buyer-loading");
        loading.classList.remove("hidden");
 

    const url = `/Report/GetBuyerActivityReport?dateFrom=${dates.from}&dateTo=${dates.to}`;

        fetch(url)
            .then(res => {
                if (!res.ok) return res.text().then(t => { throw new Error(t); });
                return res.blob();
            })
            .then(blob => {
                const link = document.createElement("a");
                link.href = URL.createObjectURL(blob);
               link.download = `reporte-compradores-${dates.from}-${dates.to}.pdf`;
                link.click();
            })
            .catch(err => {
                const errorEl = document.getElementById("buyer-error");
                errorEl.textContent = err.message || "Error al generar el reporte.";
                errorEl.classList.remove("hidden");
            })
            .finally(() => loading.classList.add("hidden"));
    }

    function generateSystemReport() {
        const dates = validateDates("system-date-from", "system-date-to", "system-error");
        if (!dates) return;

        const viz = document.querySelector('input[name="system-viz"]:checked').value;
        const loading = document.getElementById("system-loading");
        loading.classList.remove("hidden");

    const url = `/Report/GetSystemActivityReport?dateFrom=${dates.from}&dateTo=${dates.to}`;

        fetch(url)
            .then(res => {
                if (!res.ok) return res.text().then(t => { throw new Error(t); });
                return res.json();
            })
            .then(data => {
                if (viz === "pdf" || viz === "both") {
              const pdfUrl = `/Report/GetSystemActivityReportPdf?dateFrom=${dates.from}&dateTo=${dates.to}`;
                    const link = document.createElement("a");
                    link.href = pdfUrl;
                    link.download = `reporte-sistema-${dates.from}-${dates.to}.pdf`;
                    link.click();
                }

                if (viz === "chart" || viz === "both") {
                    renderSystemChart(data);
                }
            })
            .catch(err => {
                const errorEl = document.getElementById("system-error");
                errorEl.textContent = err.message || "Error al consultar el registro.";
                errorEl.classList.remove("hidden");
            })
            .finally(() => loading.classList.add("hidden"));
    }

    function renderSystemChart(data) {
        const chartArea = document.getElementById("system-chart-area");
        chartArea.classList.remove("hidden");

        document.getElementById("stat-created").textContent = data.auctionsCreated ?? "—";
        document.getElementById("stat-bids").textContent = data.bidsPlaced ?? "—";
        document.getElementById("stat-finished").textContent = data.auctionsFinished ?? "—";

        const ctx = document.getElementById("system-chart").getContext("2d");

        if (systemChart) systemChart.destroy();

        systemChart = new Chart(ctx, {
            type: "bar",
            data: {
                labels: ["Subastas Creadas", "Pujas Realizadas", "Subastas Finalizadas"],
                datasets: [{
                    label: "Actividad del Sistema",
                    data: [data.auctionsCreated, data.bidsPlaced, data.auctionsFinished],
                    backgroundColor: [
                        "rgba(234, 179, 8, 0.4)",
                        "rgba(185, 28, 28, 0.4)",
                        "rgba(120, 113, 108, 0.4)"
                    ],
                    borderColor: [
                        "rgba(234, 179, 8, 0.9)",
                        "rgba(185, 28, 28, 0.9)",
                        "rgba(120, 113, 108, 0.9)"
                    ],
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    x: {
                        ticks: { color: "#a8a29e", font: { family: "Cinzel", size: 10 } },
                        grid: { color: "rgba(120, 113, 108, 0.1)" }
                    },
                    y: {
                        beginAtZero: true,
                        ticks: { color: "#a8a29e", font: { size: 10 } },
                        grid: { color: "rgba(120, 113, 108, 0.1)" }
                    }
                }
            }
        });
    }
</script>

<style>
    @@keyframes rise {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes float {
        0%, 100% {
            transform: translateY(0) translateX(0);
            opacity: 0;
        }

        10% {
            opacity: 1;
        }

        90% {
            opacity: 0.6;
        }

        100% {
            transform: translateY(-100vh) translateX(20px);
            opacity: 0;
        }
    }

    .animate-fade-in {
        animation: fadeIn 1.5s ease-out forwards;
    }

    .ember {
        position: absolute;
        width: 3px;
        height: 3px;
        border-radius: 50%;
        background: #f97316;
        box-shadow: 0 0 6px #f97316, 0 0 12px #ea580c;
        animation: float linear infinite;
        bottom: -10px;
    }

    .ember-1 {
        left: 10%;
        animation-duration: 8s;
        animation-delay: 0s;
    }

    .ember-2 {
        left: 30%;
        animation-duration: 11s;
        animation-delay: 2s;
    }

    .ember-3 {
        left: 60%;
        animation-duration: 9s;
        animation-delay: 4s;
    }

    .ember-4 {
        left: 85%;
        animation-duration: 13s;
        animation-delay: 1s;
    }

    .ash {
        position: absolute;
        width: 2px;
        height: 2px;
        border-radius: 50%;
        background: #9ca3af;
        box-shadow: 0 0 4px #6b7280;
        animation: float linear infinite;
        bottom: -10px;
    }

    .ash-1 {
        left: 20%;
        animation-duration: 12s;
        animation-delay: 1s;
    }

    .ash-2 {
        left: 50%;
        animation-duration: 15s;
        animation-delay: 3s;
    }

    .ash-3 {
        left: 80%;
        animation-duration: 10s;
        animation-delay: 5s;
    }

    @@keyframes grain {
        0%, 100% {
            transform: translate(0, 0);
        }

        25% {
            transform: translate(1px, 1px);
        }

        50% {
            transform: translate(-1px, 0);
        }

        75% {
            transform: translate(0, -1px);
        }
    }

    .grain-overlay {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 100;
        opacity: 0.035;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
        animation: grain 0.5s steps(1) infinite;
    }

    input[type="date"]::-webkit-calendar-picker-indicator {
        filter: invert(0.4) sepia(1) saturate(2) hue-rotate(10deg);
        cursor: pointer;
    }

    input[type="date"] {
        color-scheme: dark;
    }
</style>
'''

with open("Reports.cshtml", "w", encoding="utf-8") as f:
    f.write(report_page)

print("Archivo generado exitosamente")