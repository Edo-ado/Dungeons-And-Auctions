                    </div>

                    <button onclick="generateSystemReport()"
                            class="group/btn relative w-full px-6 py-3 bg-transparent border border-yellow-800 text-yellow-600 uppercase tracking-[0.2em] text-xs font-bold transition-all duration-300 hover:border-yellow-500 hover:text-yellow-400 hover:shadow-[0_0_20px_rgba(180,130,0,0.2)]">
                        <span class="flex items-center justify-center gap-2">
                            <span>🗡</span>
                            <span>Consultar el Registro</span>
                        </span>
                    </button>

                    <div id="system-loading" class="hidden text-center py-2">
                        <span class="text-yellow-700 text-xs tracking-widest animate-pulse">Invocando los archivos...</span>
                    </div>
                </div>

                <!-- Área de gráfica del sistema -->
                <div id="system-chart-area" class="hidden mt-6 border-t border-yellow-900/40 pt-6">
                    <h3 class="text-yellow-700 text-xs tracking-widest uppercase text-center mb-4">Actividad del Periodo</h3>
                    <div class="grid grid-cols-3 gap-3">
                        <div class="bg-[#1a1412] border border-yellow-900/40 p-4 text-center">
                            <div id="stat-created" class="text-yellow-500 text-2xl font-bold">—</div>
                            <div class="text-stone-500 text-xs mt-1 tracking-wider uppercase">Creadas</div>
                        </div>
                        <div class="bg-[#1a1412] border border-red-900/40 p-4 text-center">
                            <div id="stat-bids" class="text-red-400 text-2xl font-bold">—</div>
                            <div class="text-stone-500 text-xs mt-1 tracking-wider uppercase">Pujas</div>
                        </div>
                        <div class="bg-[#1a1412] border border-yellow-900/40 p-4 text-center">
                            <div id="stat-finished" class="text-stone-300 text-2xl font-bold">—</div>
                            <div class="text-stone-500 text-xs mt-1 tracking-wider uppercase">Finalizadas</div>
                        </div>
