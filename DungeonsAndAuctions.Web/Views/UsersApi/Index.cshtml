@model IEnumerable<D_A.Web.Models.Api.UserApiDto>

@{
    ViewData["Title"] = "Users API";
}

<div class="relative min-h-screen bg-[#1a1412] font-['Cinzel'] p-8">
    <h1 class="text-3xl text-yellow-500 mb-8 text-center uppercase tracking-widest">Usuarios</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
        @foreach (var user in Model)
        {
            <div class="border border-yellow-900 bg-[#2a1f1a] p-6 hover:border-yellow-600 transition">
                <h2 class="text-yellow-500 text-lg mb-2">@user.UserName</h2>
                <p class="text-stone-400 text-sm">@user.FirstName @user.LastName</p>
                <p class="text-stone-500 text-xs mt-1">@user.Email</p>
                <p class="text-stone-500 text-xs">@user.RoleName</p>
                <a asp-controller="UsersApi" asp-action="Details" asp-route-id="@user.Id"
                   class="mt-4 inline-block text-red-500 hover:text-yellow-400 text-xs uppercase tracking-widest transition">
                    Ver detalle →
                </a>
            </div>
        }
    </div>
</div>