@using D_A.Infraestructure.Models
@model Users
@{
    ViewData["Title"] = "Mi Perfil";
    var bids = ViewBag.Bids as ICollection<AuctionBidHistory> ?? new List<AuctionBidHistory>();
    var auctions = ViewBag.Auctions as ICollection<Auctions> ?? new List<Auctions>();
    var payments = ViewBag.Payments as ICollection<Payment> ?? new List<Payment>();
}

<div class="relative min-h-screen overflow-hidden font-['Cinzel']" style="background-color: #1a1412;">
    <div class="grain-overlay"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-transparent to-black/80 pointer-events-none"></div>

    <!-- Partículas -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="ember ember-1"></div><div class="ember ember-2"></div>
        <div class="ember ember-3"></div><div class="ash ash-1"></div>
        <div class="ash ash-2"></div>
    </div>

    <div class="relative z-10 max-w-6xl mx-auto px-6 py-12">

        <!-- ══ ENCABEZADO ══ -->
        <div class="text-center mb-12 animate-fade-in">
            <div class="flex items-center justify-center gap-4 mb-3">
                <div class="h-px w-20 bg-gradient-to-r from-transparent to-yellow-700"></div>
                <span class="text-red-700 text-xl">⚔</span>
                <div class="h-px w-20 bg-gradient-to-l from-transparent to-yellow-700"></div>
            </div>
            <p class="text-yellow-600 text-xs tracking-[0.5em] uppercase mb-1">El Pergamino de</p>
            <h1 class="text-yellow-500 text-3xl font-bold tracking-widest uppercase">
                @Model.FirstName @Model.LastName
            </h1>
            <p class="text-stone-500 text-xs font-serif italic mt-1">@Model.UserName • Miembro desde @Model.RegisterDate.ToString("dd/MM/yyyy")</p>
        </div>

        <!-- ══ NOTIFICACIONES ══ -->
        @if (TempData["Success"] != null)
        {
            <div class="mb-6 border border-green-800/60 bg-green-950/40 px-4 py-3 text-green-400 text-xs font-serif italic text-center">
                ⚜ @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="mb-6 border border-red-900/60 bg-red-950/40 px-4 py-3 text-red-400 text-xs font-serif italic text-center">
                ⚠ @TempData["Error"]
            </div>
        }

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

            <!-- ══ COLUMNA IZQUIERDA: Info + Editar + Contraseña ══ -->
            <div class="lg:col-span-1 space-y-6">

                <!-- Info del perfil -->
                <div class="relative border border-yellow-900/50 bg-[#2a1f1a]/90 p-6">
                    <div class="absolute top-2 left-2 w-3 h-3 border-t border-l border-yellow-800"></div>
                    <div class="absolute top-2 right-2 w-3 h-3 border-t border-r border-yellow-800"></div>
                    <div class="absolute bottom-2 left-2 w-3 h-3 border-b border-l border-yellow-800"></div>
                    <div class="absolute bottom-2 right-2 w-3 h-3 border-b border-r border-yellow-800"></div>

                    <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-[#1a1412] px-2">
                        <span class="text-yellow-500 text-lg">♛</span>
                    </div>

                    <h3 class="text-yellow-600 uppercase tracking-[0.2em] text-xs font-bold text-center mb-5 mt-1">Datos del Reino</h3>

                    <div class="space-y-3 text-xs">
                        <div class="flex justify-between border-b border-yellow-900/20 pb-2">
                            <span class="text-stone-500 uppercase tracking-wider">Correo</span>
                            <span class="text-stone-300 font-serif">@Model.Email</span>
                        </div>
                        <div class="flex justify-between border-b border-yellow-900/20 pb-2">
                            <span class="text-stone-500 uppercase tracking-wider">País</span>
                            <span class="text-stone-300 font-serif">@Model.Country?.Name</span>
                        </div>
                        <div class="flex justify-between border-b border-yellow-900/20 pb-2">
                            <span class="text-stone-500 uppercase tracking-wider">Género</span>
                            <span class="text-stone-300 font-serif">@Model.Gender?.Name</span>
                        </div>
                        <div class="flex justify-between border-b border-yellow-900/20 pb-2">
                            <span class="text-stone-500 uppercase tracking-wider">Nacimiento</span>
                            <span class="text-stone-300 font-serif">@Model.BirthDate.ToString("dd/MM/yyyy")</span>
                        </div>
                        <div class="flex justify-between border-b border-yellow-900/20 pb-2">
                            <span class="text-stone-500 uppercase tracking-wider">Teléfono</span>
                            <span class="text-stone-300 font-serif">@(Model.PhoneNumber ?? "—")</span>
                        </div>
                        <div class="flex justify-between border-b border-yellow-900/20 pb-2">
                            <span class="text-stone-500 uppercase tracking-wider">Rol</span>
                            <span class="text-yellow-600 font-bold uppercase tracking-wider">@Model.Role?.Name</span>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.AboutMe))
                        {
                            <div class="pt-1">
                                <span class="text-stone-500 uppercase tracking-wider block mb-1">Sobre mí</span>
                                <p class="text-stone-400 font-serif italic leading-relaxed">@Model.AboutMe</p>
                            </div>
                        }
                    </div>
                </div>

                <!-- Editar perfil -->
                <div class="relative border border-yellow-900/50 bg-[#2a1f1a]/90 p-6">
                    <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-[#1a1412] px-2">
                        <span class="text-red-700 text-base">⚜</span>
                    </div>
                    <h3 class="text-yellow-600 uppercase tracking-[0.2em] text-xs font-bold text-center mb-5 mt-1">Actualizar Perfil</h3>

                    <form asp-controller="Profile" asp-action="UpdateProfile" method="post" class="space-y-4">
                        @Html.AntiForgeryToken()
                        <div>
                            <label class="text-yellow-700 text-xs tracking-widest uppercase block mb-1">Nombre</label>
                            <input type="text" name="firstName" value="@Model.FirstName"
                                   class="w-full bg-[#1a1412] border border-yellow-900/60 text-stone-300 text-xs px-3 py-2 focus:outline-none focus:border-yellow-600 transition-colors" />
                        </div>
                        <div>
                            <label class="text-yellow-700 text-xs tracking-widest uppercase block mb-1">Apellido</label>
                            <input type="text" name="lastName" value="@Model.LastName"
                                   class="w-full bg-[#1a1412] border border-yellow-900/60 text-stone-300 text-xs px-3 py-2 focus:outline-none focus:border-yellow-600 transition-colors" />
                        </div>
                        <div>
                            <label class="text-yellow-700 text-xs tracking-widest uppercase block mb-1">Teléfono</label>
                            <input type="text" name="phoneNumber" value="@Model.PhoneNumber"
                                   class="w-full bg-[#1a1412] border border-yellow-900/60 text-stone-300 text-xs px-3 py-2 focus:outline-none focus:border-yellow-600 transition-colors" />
                        </div>
                        <div>
                            <label class="text-yellow-700 text-xs tracking-widest uppercase block mb-1">Sobre mí</label>
                            <textarea name="aboutMe" rows="3"
                                      class="w-full bg-[#1a1412] border border-yellow-900/60 text-stone-300 text-xs px-3 py-2 focus:outline-none focus:border-yellow-600 transition-colors resize-none font-serif italic">@Model.AboutMe</textarea>
                        </div>
                        <button type="submit"
                                class="w-full px-4 py-2 bg-transparent border border-yellow-800 text-yellow-600 uppercase tracking-[0.2em] text-xs font-bold hover:border-yellow-500 hover:text-yellow-400 transition-all duration-300">
                            ⚜ Guardar Cambios
                        </button>
                    </form>
                </div>

                <!-- Cambiar contraseña -->
                <div class="relative border border-yellow-900/50 bg-[#2a1f1a]/90 p-6">
                    <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-[#1a1412] px-2">
                        <span class="text-red-700 text-base">🗡</span>
                    </div>
                    <h3 class="text-yellow-600 uppercase tracking-[0.2em] text-xs font-bold text-center mb-5 mt-1">Cambiar Contraseña</h3>

                    <form asp-controller="Profile" asp-action="ChangePassword" method="post" class="space-y-4">
                        @Html.AntiForgeryToken()
                        <div>
                            <label class="text-yellow-700 text-xs tracking-widest uppercase block mb-1">Contraseña Actual</label>
                            <input type="password" name="currentPassword" placeholder="••••••••"
                                   class="w-full bg-[#1a1412] border border-yellow-900/60 text-stone-300 text-xs px-3 py-2 focus:outline-none focus:border-yellow-600 transition-colors" />
                        </div>
                        <div>
                            <label class="text-yellow-700 text-xs tracking-widest uppercase block mb-1">Nueva Contraseña</label>
                            <input type="password" name="newPassword" placeholder="••••••••"
                                   class="w-full bg-[#1a1412] border border-yellow-900/60 text-stone-300 text-xs px-3 py-2 focus:outline-none focus:border-yellow-600 transition-colors" />
                        </div>
                        <div>
                            <label class="text-yellow-700 text-xs tracking-widest uppercase block mb-1">Confirmar Contraseña</label>
                            <input type="password" name="confirmNewPassword" placeholder="••••••••"
                                   class="w-full bg-[#1a1412] border border-yellow-900/60 text-stone-300 text-xs px-3 py-2 focus:outline-none focus:border-yellow-600 transition-colors" />
                        </div>
                        <button type="submit"
                                class="w-full px-4 py-2 bg-red-900 border border-red-700 text-yellow-100 uppercase tracking-[0.2em] text-xs font-bold hover:bg-red-800 hover:border-yellow-600 transition-all duration-300">
                            🗡 Actualizar Contraseña
                        </button>
                    </form>
                </div>
            </div>

            <!-- ══ COLUMNA DERECHA: Historial con tabs ══ -->
            <div class="lg:col-span-2">
                <div class="relative border border-yellow-900/50 bg-[#2a1f1a]/90">
                    <div class="absolute top-2 left-2 w-3 h-3 border-t border-l border-yellow-800"></div>
                    <div class="absolute top-2 right-2 w-3 h-3 border-t border-r border-yellow-800"></div>
                    <div class="absolute bottom-2 left-2 w-3 h-3 border-b border-l border-yellow-800"></div>
                    <div class="absolute bottom-2 right-2 w-3 h-3 border-b border-r border-yellow-800"></div>

                    <!-- Tabs -->
                    <div class="flex border-b border-yellow-900/40">
                        <button onclick="showTab('bids')" id="tab-bids"
                                class="tab-btn active-tab flex-1 py-3 text-xs uppercase tracking-widest transition-all duration-200">
                            ⚔ Pujas (@bids.Count)
                        </button>
                        <button onclick="showTab('auctions')" id="tab-auctions"
                                class="tab-btn flex-1 py-3 text-xs uppercase tracking-widest transition-all duration-200">
                            ♛ Subastas (@auctions.Count)
                        </button>
                        <button onclick="showTab('payments')" id="tab-payments"
                                class="tab-btn flex-1 py-3 text-xs uppercase tracking-widest transition-all duration-200">
                            ⚜ Pagos (@payments.Count)
                        </button>
                    </div>

                    <div class="p-6">

                        <!-- TAB: PUJAS -->
                        <div id="content-bids" class="tab-content">
                            @if (!bids.Any())
                            {
                                <p class="text-stone-600 font-serif italic text-center py-8 text-sm">
                                    "Aún no has cruzado espadas en ninguna subasta."
                                </p>
                            }
                            else
                            {
                                <div class="overflow-x-auto">
                                    <table class="w-full text-xs">
                                        <thead>
                                            <tr class="border-b border-yellow-900/40">
                                                <th class="text-yellow-700 uppercase tracking-wider text-left pb-2">Objeto</th>
                                                <th class="text-yellow-700 uppercase tracking-wider text-left pb-2">Monto</th>
                                                <th class="text-yellow-700 uppercase tracking-wider text-left pb-2">Fecha</th>
                                                <th class="text-yellow-700 uppercase tracking-wider text-left pb-2">Estado</th>
                                            </tr>
                                        </thead>
                                        <tbody class="divide-y divide-yellow-900/20">
                                            @foreach (var bid in bids)
                                            {
                                                <tr class="hover:bg-yellow-900/10 transition-colors">
                                                    <td class="py-2 text-stone-300 font-serif">@bid.Auction?.IdobjectNavigation?.Name</td>
                                                    <td class="py-2 text-yellow-500 font-bold">₡@bid.Amount.ToString("N2")</td>
                                                    <td class="py-2 text-stone-400">@bid.BidDate.ToString("dd/MM/yyyy HH:mm")</td>
                                                    <td class="py-2">
                                                        @if (bid.IsLastBid)
                                                        {
                                                            <span class="text-green-400 text-xs">● Ganando</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="text-stone-500 text-xs">● Superada</span>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>

                        <!-- TAB: SUBASTAS -->
                        <div id="content-auctions" class="tab-content hidden">
                            @if (!auctions.Any())
                            {
                                <p class="text-stone-600 font-serif italic text-center py-8 text-sm">
                                    "No has creado ninguna subasta en el reino aún."
                                </p>
                            }
                            else
                            {
                                <div class="overflow-x-auto">
                                    <table class="w-full text-xs">
                                        <thead>
                                            <tr class="border-b border-yellow-900/40">
                                                <th class="text-yellow-700 uppercase tracking-wider text-left pb-2">Objeto</th>
                                                <th class="text-yellow-700 uppercase tracking-wider text-left pb-2">Precio Base</th>
                                                <th class="text-yellow-700 uppercase tracking-wider text-left pb-2">Inicio</th>
                                                <th class="text-yellow-700 uppercase tracking-wider text-left pb-2">Fin</th>
                                                <th class="text-yellow-700 uppercase tracking-wider text-left pb-2">Estado</th>
                                            </tr>
                                        </thead>
                                        <tbody class="divide-y divide-yellow-900/20">
                                            @foreach (var auction in auctions)
                                            {
                                                <tr class="hover:bg-yellow-900/10 transition-colors">
                                                    <td class="py-2 text-stone-300 font-serif">@auction.IdobjectNavigation?.Name</td>
                                                    <td class="py-2 text-yellow-500 font-bold">₡@auction.BasePrice.ToString("N2")</td>
                                                    <td class="py-2 text-stone-400">@auction.StartDate.ToString("dd/MM/yyyy")</td>
                                                    <td class="py-2 text-stone-400">@auction.EndDate.ToString("dd/MM/yyyy")</td>
                                                    <td class="py-2">
                                                        @if (auction.IsActive)
                                                        {
                                                            <span class="text-green-400 text-xs">● Activa</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="text-stone-500 text-xs">● Finalizada</span>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>

                        <!-- TAB: PAGOS -->
                        <div id="content-payments" class="tab-content hidden">
                            @if (!payments.Any())
                            {
                                <p class="text-stone-600 font-serif italic text-center py-8 text-sm">
                                    "Ninguna transacción registrada en los archivos del reino."
                                </p>
                            }
                            else
                            {
                                <div class="overflow-x-auto">
                                    <table class="w-full text-xs">
                                        <thead>
                                            <tr class="border-b border-yellow-900/40">
                                                <th class="text-yellow-700 uppercase tracking-wider text-left pb-2">Subasta</th>
                                                <th class="text-yellow-700 uppercase tracking-wider text-left pb-2">Monto</th>
                                                <th class="text-yellow-700 uppercase tracking-wider text-left pb-2">Fecha</th>
                                                <th class="text-yellow-700 uppercase tracking-wider text-left pb-2">Estado</th>
                                            </tr>
                                        </thead>
                                        <tbody class="divide-y divide-yellow-900/20">
                                            @foreach (var payment in payments)
                                            {
                                                <tr class="hover:bg-yellow-900/10 transition-colors">
                                                    <td class="py-2 text-stone-300 font-serif">@payment.Auction?.IdobjectNavigation?.Name</td>
                                                    <td class="py-2 text-yellow-500 font-bold">₡@payment.Amount?.ToString("N2")</td>
                                                    <td class="py-2 text-stone-400">@payment.DateCreated?.ToString("dd/MM/yyyy")</td>
                                                    <td class="py-2">
                                                        <span class="text-xs @(payment.PaymentStatus?.Status == "Confirmado" ? "text-green-400" : "text-yellow-600")">
                                                            ● @(payment.PaymentStatus?.Status ?? "—")
                                                        </span>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function showTab(tab) {
        document.querySelectorAll('.tab-content').forEach(c => c.classList.add('hidden'));
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active-tab'));
        document.getElementById('content-' + tab).classList.remove('hidden');
        document.getElementById('tab-' + tab).classList.add('active-tab');
    }
</script>

<style>
    .tab-btn {
        color: #78716c;
    }

        .tab-btn:hover {
            color: #ca8a04;
        }

    .active-tab {
        color: #eab308;
        border-bottom: 2px solid #854d0e;
    }

    @@keyframes float {
        0%, 100% {
            transform: translateY(0) translateX(0);
            opacity: 0;
        }

        10% {
            opacity: 1;
        }

        90% {
            opacity: 0.6;
        }

        100% {
            transform: translateY(-100vh) translateX(20px);
            opacity: 0;
        }
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    .animate-fade-in {
        animation: fadeIn 1s ease-out forwards;
    }

    .ember {
        position: absolute;
        width: 3px;
        height: 3px;
        border-radius: 50%;
        background: #f97316;
        box-shadow: 0 0 6px #f97316;
        animation: float linear infinite;
        bottom: -10px;
    }

    .ember-1 {
        left: 15%;
        animation-duration: 8s;
    }

    .ember-2 {
        left: 50%;
        animation-duration: 11s;
        animation-delay: 2s;
    }

    .ember-3 {
        left: 80%;
        animation-duration: 9s;
        animation-delay: 4s;
    }

    .ash {
        position: absolute;
        width: 2px;
        height: 2px;
        border-radius: 50%;
        background: #9ca3af;
        animation: float linear infinite;
        bottom: -10px;
    }

    .ash-1 {
        left: 30%;
        animation-duration: 12s;
        animation-delay: 1s;
    }

    .ash-2 {
        left: 70%;
        animation-duration: 15s;
        animation-delay: 3s;
    }

    @@keyframes grain {
        0%, 100% {
            transform: translate(0,0);
        }

        25% {
            transform: translate(1px,1px);
        }

        50% {
            transform: translate(-1px,0);
        }

        75% {
            transform: translate(0,-1px);
        }
    }

    .grain-overlay {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 100;
        opacity: 0.035;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
        animation: grain 0.5s steps(1) infinite;
    }
</style>