@model IEnumerable<D_A.Application.DTOs.UsersDTO>

@{
    ViewData["Title"] = "Registro de Ciudadanos";
}

<div class="min-h-screen bg-[#1a1412] py-12 px-4 sm:px-8 font-['Cinzel']">

    <div class="max-w-7xl mx-auto mb-10 flex flex-col md:flex-row justify-between items-center border-b-2 border-yellow-700 pb-6 gap-6">
        <div>
            <h1 class="text-4xl md:text-5xl font-bold text-red-600 tracking-widest uppercase drop-shadow-[0_2px_4px_rgba(0,0,0,0.8)]">
                Registro de Usuarios
            </h1>
            <p class="text-yellow-700 italic mt-2 text-lg">"Gobernando los reinos con mano de hierro y datos precisos."</p>
        </div>
    </div>

    <div class="max-w-7xl mx-auto overflow-hidden rounded-sm border border-yellow-900 shadow-[0_20px_50px_rgba(0,0,0,0.9)] bg-[#2a1f1a]">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-[#3d2b24] text-yellow-500 uppercase text-xs  border-b border-yellow-800">
                        <th class="px-4 py-4 font-bold">Nombre Completo</th>
   
                        <th class="px-4 py-4 font-bold">País</th>
                        <th class="px-4 py-4 font-bold">Rol</th>
                        <th class="px-4 py-4 font-bold text-center">Estado</th>
                        <th class="px-4 py-4 font-bold text-center">Bloqueado</th>
                        <th class="px-4 py-4 font-bold text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody class="text-stone-300 divide-y divide-yellow-900/30">
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-[#362822] transition-colors duration-200 group">

                          
                            <td class="px-4 py-3">
                                <div class="text-sm font-bold text-stone-200 group-hover:text-yellow-400 transition-colors uppercase tracking-tight">
                                    @item.FirstName @item.LastName
                                </div>
                                <div class="text-[10px] text-yellow-800 font-mono mt-1 uppercase">Ref: #@item.Id</div>
                                @if (item.RegisterDate != new DateOnly(2000, 1, 1))
                                {
                                    <div class="text-[9px] text-stone-600 mt-0.5 font-serif italic">
                                        Registrado: @item.RegisterDate.ToString("dd/MM/yyyy")
                                    </div>
                                }
                            </td>


                            <td class="px-4 py-3">
                                <span class="text-stone-400 italic text-xs">
                                    @(string.IsNullOrEmpty(item.CountryName) ? "—" : item.CountryName)
                                </span>
                            </td>

                 
                            <td class="px-4 py-3">
                                <span class="px-2 py-0.5 rounded-full bg-red-900/30 border border-red-800 text-red-400 text-[10px] uppercase tracking-wide">
                                    @item.RoleName
                                </span>
                            </td>

                
                            <td class="px-4 py-3 text-center">
                                @if (item.Active)
                                {
                                    <span class="inline-flex items-center text-green-500 uppercase text-[10px] font-bold tracking-widest">
                                        <span class="h-2 w-2 rounded-full bg-green-500 mr-1.5 shadow-[0_0_8px_rgba(34,197,94,0.8)]"></span>
                                        Activo
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center text-red-700 uppercase text-[10px] font-bold tracking-widest">
                                        <span class="h-2 w-2 rounded-full bg-red-700 mr-1.5"></span>
                                        Inactivo
                                    </span>
                                }
                            </td>

                 
                            <td class="px-4 py-3 text-center">
                                @if (item.IsBlocked)
                                {
                                    <span class="inline-flex items-center text-orange-500 uppercase text-[10px] font-bold tracking-widest">
                                        <span class="h-2 w-2 rounded-full bg-orange-500 mr-1.5 shadow-[0_0_8px_rgba(249,115,22,0.8)]"></span>
                                        Sí
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center text-stone-600 uppercase text-[10px] tracking-widest">
                                        <span class="h-2 w-2 rounded-full bg-stone-700 mr-1.5"></span>
                                        No
                                    </span>
                                }
                            </td>

                            <td class="px-4 py-3 text-center text-[10px] font-bold">
                                <div class="flex items-center justify-center gap-2 flex-wrap">
                                    <a asp-action="Details" asp-route-id="@item.Id"
                                       class="text-blue-500 hover:text-blue-300 transition-all uppercase tracking-wider">Ver</a>
                                    <span class="text-yellow-900">|</span>
                                    <a asp-action="Edit" asp-route-id="@item.Id"
                                       class="text-yellow-600 hover:text-yellow-400 transition-all uppercase tracking-wider">Editar</a>
                                    <span class="text-yellow-900">|</span>
                                    <form asp-action="ToggleBlock" asp-route-id="@item.Id" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="@(item.IsBlocked ? "text-green-600 hover:text-green-400" : "text-orange-600 hover:text-orange-400") transition-all uppercase tracking-wider">
                                            @(item.IsBlocked ? "Desbloquear" : "Bloquear")
                                        </button>
                                    </form>
                                    <span class="text-yellow-900">|</span>
                                    <form asp-action="ToggleActive" asp-route-id="@item.Id" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="@(item.Active ? "text-red-700 hover:text-red-500" : "text-green-700 hover:text-green-500") transition-all uppercase tracking-wider">
                                            @(item.Active ? "Desactivar" : "Activar")
                                        </button>
                                    </form>
                                </div>
                            </td>

                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-8 text-center">
        <div class="flex justify-center items-center gap-4 opacity-30">
            <div class="h-px w-24 bg-yellow-700"></div>
            <img src="/Images/Logo/ShortLogo.png" class="h-8 grayscale" alt="sepia-logo" />
            <div class="h-px w-24 bg-yellow-700"></div>
        </div>
    </div>
</div>

<style>
    @@keyframes grain {
        0%, 100% {
            transform: translate(0, 0);
        }

        25% {
            transform: translate(1px, 1px);
        }

        50% {
            transform: translate(-1px, 0);
        }

        75% {
            transform: translate(0, -1px);
        }
    }

    .grain-overlay {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 100;
        opacity: 0.035;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
        animation: grain 0.5s steps(1) infinite;
    }
</style>
